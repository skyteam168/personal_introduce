# Site
NEXT_PUBLIC_SITE_URL=https://personalintroduce-ten.vercel.app

# Database (Supabase → Settings → Database → Connection string → URI)
# Use "Transaction" pooler mode, append ?sslmode=require
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# Auth.js — generate: openssl rand -base64 32
AUTH_SECRET=your-random-secret-here

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Only these emails can access /admin (comma-separated)
ADMIN_EMAILS=royaldragontasty@gmail.com
